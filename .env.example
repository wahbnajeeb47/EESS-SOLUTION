# Copy these into Vercel → Project → Settings → Environment Variables
# (Do NOT commit a real .env file with actual secrets to GitHub.)

# MongoDB Atlas connection string (from Atlas → Connect → Drivers)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eess_solutions?retryWrites=true&w=majority

# SMTP settings for sending notification emails (any provider: Gmail, Zoho, SendGrid, etc.)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Where submissions get emailed to
ADMIN_EMAIL=contact@eess-solutions.com

# The "From" address/name used when sending — should be on your own domain
MAIL_FROM_ADDRESS=no-reply@eess-solutions.com
MAIL_FROM_NAME=EESS Solutions Website
